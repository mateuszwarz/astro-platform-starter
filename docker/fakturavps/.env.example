# ============================================================
# FakturaVPS — Szablon zmiennych środowiskowych
# Skopiuj ten plik jako .env i uzupełnij wartości
# NIGDY nie commituj .env do repozytorium!
# ============================================================

# Środowisko: "production" wyłącza /docs i /redoc
APP_ENV=production

# Baza danych
POSTGRES_USER=faktura
POSTGRES_PASSWORD=ZMIEN_NA_SILNE_HASLO
POSTGRES_DB=fakturavps
DATABASE_URL=postgresql://faktura:ZMIEN_NA_SILNE_HASLO@postgres:5432/fakturavps

# JWT — wygeneruj: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=WYGENERUJ_LOSOWY_KLUCZ_MIN_32_ZNAKI
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=1

# Redis
REDIS_URL=redis://:redis_default_pass@redis:6379/0
REDIS_PASSWORD=redis_default_pass

# CORS — podaj domenę swojego serwera (przecinkiem jeśli kilka)
# Przykład: https://faktura.twojafirma.pl
CORS_ORIGINS=https://twoja-domena.pl

# Hasło admina przy pierwszym uruchomieniu — zmień natychmiast po zalogowaniu!
SEED_ADMIN_PASSWORD=ZMIEN_NA_SILNE_HASLO_MIN_12_ZNAKOW
